---
interface Props {
  href?: string;
  size?: 'default' | 'large';
  showLabel?: boolean;
}

const { href = '/report', size = 'default', showLabel = true } = Astro.props;
---

<a 
  href={href}
  class:list={[
    'group relative inline-flex items-center justify-center gap-3 overflow-hidden',
    'bg-toyota-red text-white font-bold uppercase tracking-wide',
    'rounded-lg transition-all duration-200',
    'hover:bg-toyota-red-dark hover:scale-[1.02] active:scale-[0.98]',
    'focus:outline-none focus:ring-4 focus:ring-toyota-red/30',
    'shadow-lg shadow-toyota-red/30',
    size === 'large' ? 'px-10 py-5 text-xl' : 'px-8 py-4 text-base',
    'min-h-[56px]'
  ]}
>
  <!-- Pulse Effect -->
  <span class="absolute inset-0 rounded-lg bg-toyota-red animate-ping opacity-75"></span>
  
  <!-- Icon -->
  <svg 
    class:list={['relative z-10', size === 'large' ? 'w-7 h-7' : 'w-6 h-6']} 
    fill="none" 
    stroke="currentColor" 
    viewBox="0 0 24 24"
  >
    <path 
      stroke-linecap="round" 
      stroke-linejoin="round" 
      stroke-width="2" 
      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
    />
  </svg>
  
  {showLabel && <span class="relative z-10">Emergency</span>}
</a>

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 0.75;
      transform: scale(1);
    }
    50% {
      opacity: 0;
      transform: scale(1.1);
    }
  }
  
  .animate-ping {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
