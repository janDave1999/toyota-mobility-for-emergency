---
interface Props {
  variant?: 'default' | 'transparent' | 'emergency';
}

const { variant = 'default' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/emergencies', label: 'Emergencies' },
  { href: '/first-aiders', label: 'First Aiders' },
  { href: '/agencies', label: 'Agencies' },
  { href: '/about', label: 'About' },
];

const isTransparent = variant === 'transparent';
const isEmergency = variant === 'emergency';
---

<nav 
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    isEmergency ? 'bg-critical' : isTransparent ? 'bg-transparent' : 'bg-white border-b border-gray-200'
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-[72px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class:list={[
          isEmergency ? 'bg-white' : 'bg-toyota-red',
          'w-10 h-10 rounded-lg flex items-center justify-center transition-transform group-hover:scale-105'
        ]}>
          <svg class={isEmergency ? 'text-critical' : 'text-white'} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class:list={[
          'font-bold text-lg lg:text-xl tracking-tight',
          isEmergency ? 'text-white' : 'text-gray-900'
        ]}>
          Toyota Mobility
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map(link => (
          <a 
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-toyota-red',
              isEmergency ? 'text-white/90 hover:text-white' : 'text-gray-600 hover:text-gray-900'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <!-- Emergency CTA -->
        <a 
          href="/report" 
          class:list={[
            'hidden sm:flex items-center gap-2 px-4 py-2.5 rounded-lg font-semibold text-sm transition-all hover:scale-105',
            isEmergency ? 'bg-white text-critical hover:bg-gray-100' : 'bg-toyota-red text-white hover:bg-toyota-red-dark'
          ]}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          Report Emergency
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class:list={[
            'lg:hidden p-2 rounded-lg transition-colors',
            isEmergency ? 'text-white hover:bg-white/10' : 'text-gray-600 hover:bg-gray-100'
          ]}
          aria-label="Toggle menu"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-200">
    <div class="px-4 py-4 space-y-2">
      {navLinks.map(link => (
        <a 
          href={link.href}
          class="block px-4 py-3 text-base font-medium text-gray-700 rounded-lg hover:bg-gray-50 hover:text-toyota-red"
        >
          {link.label}
        </a>
      ))}
      <a 
        href="/report" 
        class="block w-full text-center px-4 py-3 mt-4 bg-toyota-red text-white font-semibold rounded-lg hover:bg-toyota-red-dark"
      >
        Report Emergency
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

<style>
  nav {
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>
