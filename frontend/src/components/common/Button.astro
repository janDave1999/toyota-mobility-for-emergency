---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  loading?: boolean;
  fullWidth?: boolean;
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  loading = false,
  fullWidth = false,
  class: className = ''
} = Astro.props;

const variants = {
  primary: 'bg-toyota-red text-white hover:bg-toyota-red-dark focus:ring-toyota-red',
  secondary: 'bg-gray-900 text-white hover:bg-gray-800 focus:ring-gray-900',
  outline: 'border-2 border-toyota-red text-toyota-red hover:bg-toyota-red hover:text-white focus:ring-toyota-red',
  ghost: 'text-gray-700 hover:bg-gray-100 focus:ring-gray-300',
  danger: 'bg-critical text-white hover:bg-red-700 focus:ring-critical'
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg'
};

const classes = [
  'inline-flex items-center justify-center gap-2 font-semibold rounded-lg transition-all duration-200',
  'focus:outline-none focus:ring-2 focus:ring-offset-2',
  'disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100',
  'hover:scale-[1.02] active:scale-[0.98]',
  variants[variant],
  sizes[size],
  fullWidth && 'w-full',
  className
].filter(Boolean).join(' ');

const tag = href ? 'a' : 'button';
---

{tag === 'a' ? (
  <a 
    href={href}
    class={classes}
    {...(disabled && { 'aria-disabled': true })}
  >
    {loading && (
      <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    )}
    <slot />
  </a>
) : (
  <button 
    type={type}
    disabled={disabled || loading}
    class={classes}
  >
    {loading && (
      <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    )}
    <slot />
  </button>
)}
