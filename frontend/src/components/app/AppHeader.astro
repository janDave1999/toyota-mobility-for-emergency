---
interface Props {
  title: string;
  back?: { href: string; label: string };
}
const { title, back } = Astro.props;

const user = Astro.locals.user;
const activeRole = Astro.locals.activeRole;
const userRoles = user?.roles?.map(r => r.name) ?? [];
const hasMultipleRoles = userRoles.length > 1;

const ROLE_META: Record<string, { label: string; dot: string; pill: string }> = {
  ADMIN:       { label: 'Admin',       dot: 'bg-purple-500', pill: 'bg-purple-100 text-purple-700 ring-purple-200' },
  DISPATCHER:  { label: 'Dispatcher',  dot: 'bg-blue-500',   pill: 'bg-blue-100 text-blue-700 ring-blue-200'       },
  RESPONDER:   { label: 'Responder',   dot: 'bg-green-500',  pill: 'bg-green-100 text-green-700 ring-green-200'    },
  FIRST_AIDER: { label: 'First Aider', dot: 'bg-amber-500',  pill: 'bg-amber-100 text-amber-700 ring-amber-200'   },
  CITIZEN:     { label: 'Citizen',     dot: 'bg-gray-400',   pill: 'bg-gray-100 text-gray-600 ring-gray-200'       },
};

const currentMeta = activeRole
  ? (ROLE_META[activeRole] ?? { label: activeRole, dot: 'bg-gray-400', pill: 'bg-gray-100 text-gray-600 ring-gray-200' })
  : null;
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-10">
  <div class="max-w-2xl mx-auto px-4 h-14 flex items-center justify-between gap-3">

    <!-- Left: back + title -->
    <div class="flex items-center gap-3 min-w-0">
      {back && (
        <a
          href={back.href}
          class="shrink-0 p-1.5 -ml-1.5 text-gray-400 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
          aria-label={`Back to ${back.label}`}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
      )}
      <h1 class="text-base font-semibold text-gray-900 truncate">{title}</h1>
    </div>

    <!-- Right: role indicator + slot -->
    <div class="shrink-0 flex items-center gap-2">

      {currentMeta && (
        <div class="relative" id="role-switcher">

          {/* Always-visible current role pill */}
          {hasMultipleRoles ? (
            <!-- Clickable pill for multi-role users -->
            <button
              id="role-switcher-btn"
              type="button"
              aria-haspopup="listbox"
              aria-expanded="false"
              class={`flex items-center gap-1.5 pl-2 pr-2.5 py-1 rounded-full text-xs font-semibold ring-1 transition-all hover:opacity-90 ${currentMeta.pill}`}
              title="Switch role"
            >
              <span class={`w-2 h-2 rounded-full shrink-0 ${currentMeta.dot}`}></span>
              {currentMeta.label}
              <!-- Chevron down icon -->
              <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
          ) : (
            <!-- Static pill for single-role users -->
            <span class={`flex items-center gap-1.5 pl-2 pr-2.5 py-1 rounded-full text-xs font-semibold ring-1 ${currentMeta.pill}`}>
              <span class={`w-2 h-2 rounded-full shrink-0 ${currentMeta.dot}`}></span>
              {currentMeta.label}
            </span>
          )}

          {/* Dropdown — multi-role only */}
          {hasMultipleRoles && (
            <div
              id="role-switcher-dropdown"
              role="listbox"
              aria-label="Select role"
              class="hidden absolute right-0 top-full mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 py-1.5 z-50"
            >
              <p class="px-3 pb-1 pt-0.5 text-[10px] font-semibold text-gray-400 uppercase tracking-wider">
                Switch role
              </p>
              {userRoles.map(role => {
                const meta = ROLE_META[role] ?? { label: role, dot: 'bg-gray-400', pill: 'bg-gray-100 text-gray-600 ring-gray-200' };
                const isActive = role === activeRole;
                return (
                  <form method="POST" action="/api/auth/switch-role">
                    <input type="hidden" name="role" value={role} />
                    <button
                      type="submit"
                      role="option"
                      aria-selected={isActive}
                      class={`w-full flex items-center gap-2.5 px-3 py-2 text-sm text-left transition-colors
                        ${isActive
                          ? 'bg-gray-50 text-gray-900 font-semibold'
                          : 'text-gray-500 hover:bg-gray-50 hover:text-gray-900'}`}
                    >
                      <span class={`w-2.5 h-2.5 rounded-full shrink-0 ${meta.dot}`}></span>
                      {meta.label}
                      {isActive && (
                        <!-- Checkmark for active role -->
                        <svg class="w-4 h-4 ml-auto text-toyota-red shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                      )}
                    </button>
                  </form>
                );
              })}
            </div>
          )}

        </div>
      )}

      <slot />
    </div>

  </div>
</header>

<script>
  const btn = document.getElementById('role-switcher-btn');
  const dropdown = document.getElementById('role-switcher-dropdown');

  if (btn && dropdown) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdown.classList.contains('hidden');
      dropdown.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });

    document.addEventListener('click', (e) => {
      if (!document.getElementById('role-switcher')?.contains(e.target as Node)) {
        dropdown.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
