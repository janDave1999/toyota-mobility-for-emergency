---
export type ActiveTab = 'home' | 'map' | 'dashboard' | 'organization' | 'reports' | 'profile';

interface Props {
  active: ActiveTab;
  reportsBadge?: number; // unread / active incident count
}

const { active, reportsBadge = 0 } = Astro.props;

const activeRole = Astro.locals.activeRole;

const isAdmin      = activeRole === 'ADMIN';
const isDispatcher = activeRole === 'DISPATCHER';
const isResponder  = activeRole === 'RESPONDER';
const isFirstAider = activeRole === 'FIRST_AIDER';
const isPrivileged = isAdmin || isDispatcher || isResponder || isFirstAider;

const dashboardHref = isAdmin      ? '/admin/dashboard'
                    : isDispatcher ? '/dispatch/dashboard'
                    : isResponder  ? '/responder/dashboard'
                    : '/first-aider/dashboard';

const showHome         = !isAdmin && !isDispatcher && !isResponder;
const showDashboard    = isAdmin || isDispatcher;
const showOrganization = isAdmin || isDispatcher;
const showMap          = isPrivileged;
const showReports      = true;
const showProfile      = true;

// Build visible nav items to know how wide each one should be
const items = [
  showHome         && 'home',
  showDashboard    && 'dashboard',
  showMap          && 'map',
  showOrganization && 'organization',
  showReports      && 'reports',
  showProfile      && 'profile',
].filter(Boolean) as ActiveTab[];

const count = items.length;

function isActive(tab: ActiveTab) { return active === tab; }
---

<!-- ── Mobile bottom nav (hidden on md+) ──────────────────────────────── -->
<nav
  aria-label="Main navigation"
  class="md:hidden fixed bottom-0 inset-x-0 z-20 bg-white border-t border-gray-100"
  style="padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  <ul
    role="list"
    class="flex items-stretch"
    style={`grid-template-columns: repeat(${count}, 1fr);`}
  >

    {showHome && (
      <li class="flex-1">
        <a
          href="/sos"
          aria-label="Home"
          aria-current={isActive('home') ? 'page' : undefined}
          class={`flex flex-col items-center justify-center gap-1 min-h-[56px] w-full transition-colors
            ${isActive('home') ? 'text-toyota-red' : 'text-gray-400 hover:text-gray-600'}`}
        >
          {isActive('home') && <span class="absolute h-1 w-10 bg-toyota-red rounded-full -top-0.5" />}
          <svg class="w-5 h-5" fill={isActive('home') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          <span class="text-[10px] font-semibold tracking-wide">Home</span>
        </a>
      </li>
    )}

    {showDashboard && (
      <li class="flex-1">
        <a
          href={dashboardHref}
          aria-label="Dashboard"
          aria-current={isActive('dashboard') ? 'page' : undefined}
          class={`flex flex-col items-center justify-center gap-1 min-h-[56px] w-full transition-colors
            ${isActive('dashboard') ? 'text-toyota-red' : 'text-gray-400 hover:text-gray-600'}`}
        >
          <svg class="w-5 h-5" fill={isActive('dashboard') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
          </svg>
          <span class="text-[10px] font-semibold tracking-wide">Dashboard</span>
        </a>
      </li>
    )}

    {showMap && (
      <li class="flex-1">
        <a
          href="/map"
          aria-label="Map"
          aria-current={isActive('map') ? 'page' : undefined}
          class={`flex flex-col items-center justify-center gap-1 min-h-[56px] w-full transition-colors
            ${isActive('map') ? 'text-toyota-red' : 'text-gray-400 hover:text-gray-600'}`}
        >
          <svg class="w-5 h-5" fill={isActive('map') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          <span class="text-[10px] font-semibold tracking-wide">Map</span>
        </a>
      </li>
    )}

    {showOrganization && (
      <li class="flex-1">
        <a
          href="/organization"
          aria-label="Organization"
          aria-current={isActive('organization') ? 'page' : undefined}
          class={`flex flex-col items-center justify-center gap-1 min-h-[56px] w-full transition-colors
            ${isActive('organization') ? 'text-toyota-red' : 'text-gray-400 hover:text-gray-600'}`}
        >
          <svg class="w-5 h-5" fill={isActive('organization') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <span class="text-[10px] font-semibold tracking-wide">Org</span>
        </a>
      </li>
    )}

    {showReports && (
      <li class="flex-1 relative">
        <a
          href="/incidents"
          aria-label={reportsBadge > 0 ? `Reports, ${reportsBadge} active` : 'Reports'}
          aria-current={isActive('reports') ? 'page' : undefined}
          class={`flex flex-col items-center justify-center gap-1 min-h-[56px] w-full transition-colors
            ${isActive('reports') ? 'text-toyota-red' : 'text-gray-400 hover:text-gray-600'}`}
        >
          <span class="relative">
            <svg class="w-5 h-5" fill={isActive('reports') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            {reportsBadge > 0 && (
              <span class="absolute -top-1 -right-1.5 min-w-[16px] h-4 px-1 bg-toyota-red text-white text-[9px] font-bold rounded-full flex items-center justify-center leading-none">
                {reportsBadge > 99 ? '99+' : reportsBadge}
              </span>
            )}
          </span>
          <span class="text-[10px] font-semibold tracking-wide">Reports</span>
        </a>
      </li>
    )}

    {showProfile && (
      <li class="flex-1">
        <a
          href="/profile"
          aria-label="Profile"
          aria-current={isActive('profile') ? 'page' : undefined}
          class={`flex flex-col items-center justify-center gap-1 min-h-[56px] w-full transition-colors
            ${isActive('profile') ? 'text-toyota-red' : 'text-gray-400 hover:text-gray-600'}`}
        >
          <svg class="w-5 h-5" fill={isActive('profile') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span class="text-[10px] font-semibold tracking-wide">Profile</span>
        </a>
      </li>
    )}

  </ul>
</nav>

<!-- ── Desktop sidebar (md+) ──────────────────────────────────────────── -->
<aside
  aria-label="Main navigation"
  class="hidden md:flex flex-col fixed left-0 top-0 bottom-0 w-56 bg-white border-r border-gray-100 z-20 py-6 px-3 gap-1"
>
  <!-- Logo -->
  <div class="flex items-center gap-2.5 px-3 mb-6">
    <div class="w-8 h-8 bg-toyota-red rounded-lg flex items-center justify-center shrink-0">
      <span class="text-white text-sm font-bold">R</span>
    </div>
    <span class="font-bold text-gray-900 text-sm">Red Alert</span>
  </div>

  {showHome && (
    <a
      href="/sos"
      aria-current={isActive('home') ? 'page' : undefined}
      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
        ${isActive('home') ? 'bg-toyota-red/10 text-toyota-red' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}
    >
      <svg class="w-5 h-5 shrink-0" fill={isActive('home') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Home
    </a>
  )}

  {showDashboard && (
    <a
      href={dashboardHref}
      aria-current={isActive('dashboard') ? 'page' : undefined}
      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
        ${isActive('dashboard') ? 'bg-toyota-red/10 text-toyota-red' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}
    >
      <svg class="w-5 h-5 shrink-0" fill={isActive('dashboard') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
      </svg>
      Dashboard
    </a>
  )}

  {showMap && (
    <a
      href="/map"
      aria-current={isActive('map') ? 'page' : undefined}
      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
        ${isActive('map') ? 'bg-toyota-red/10 text-toyota-red' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}
    >
      <svg class="w-5 h-5 shrink-0" fill={isActive('map') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
      </svg>
      Map
    </a>
  )}

  {showOrganization && (
    <a
      href="/organization"
      aria-current={isActive('organization') ? 'page' : undefined}
      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
        ${isActive('organization') ? 'bg-toyota-red/10 text-toyota-red' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}
    >
      <svg class="w-5 h-5 shrink-0" fill={isActive('organization') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
      Organization
    </a>
  )}

  {showReports && (
    <a
      href="/incidents"
      aria-current={isActive('reports') ? 'page' : undefined}
      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
        ${isActive('reports') ? 'bg-toyota-red/10 text-toyota-red' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}
    >
      <span class="relative shrink-0">
        <svg class="w-5 h-5" fill={isActive('reports') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        {reportsBadge > 0 && (
          <span class="absolute -top-1 -right-1.5 min-w-[16px] h-4 px-1 bg-toyota-red text-white text-[9px] font-bold rounded-full flex items-center justify-center">
            {reportsBadge > 99 ? '99+' : reportsBadge}
          </span>
        )}
      </span>
      Reports
      {reportsBadge > 0 && (
        <span class="ml-auto text-[10px] font-bold bg-toyota-red text-white px-1.5 py-0.5 rounded-full">{reportsBadge}</span>
      )}
    </a>
  )}

  <!-- Push profile + logout to bottom -->
  <div class="mt-auto flex flex-col gap-1">
    {showProfile && (
      <a
        href="/profile"
        aria-current={isActive('profile') ? 'page' : undefined}
        class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          ${isActive('profile') ? 'bg-toyota-red/10 text-toyota-red' : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}
      >
        <svg class="w-5 h-5 shrink-0" fill={isActive('profile') ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Profile
      </a>
    )}
    <a
      href="/api/auth/logout"
      class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:bg-red-50 hover:text-red-600 transition-colors"
    >
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Sign out
    </a>
  </div>
</aside>
