---
import Layout from '../components/layout/Layout.astro';
import Container from '../components/layout/Container.astro';
import { Button, Card, EmergencyButton } from '../components';
---

<Layout title="Toyota Mobility for Emergency">
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-br from-gray-50 to-gray-100">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 left-10 w-72 h-72 bg-toyota-red/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-police/10 rounded-full blur-3xl"></div>
    </div>

    <Container>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div class="text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-toyota-red/10 text-toyota-red rounded-full text-sm font-medium mb-6">
            <span class="w-2 h-2 bg-toyota-red rounded-full animate-pulse"></span>
            Unified Emergency Response
          </div>
          
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
            Quick Response,<br/>
            <span class="text-toyota-red">Saving Lives</span>
          </h1>
          
          <p class="text-lg lg:text-xl text-gray-600 mb-8 max-w-xl">
            One tap to connect with Police, Ambulance, and Fire services. 
            Real-time tracking, verified responders, and instant assistance when you need it most.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <EmergencyButton size="large" />
            <Button variant="outline" size="lg" href="/learn-more">
              Learn More
            </Button>
          </div>


        </div>

        <!-- Right Content - App Preview -->
        <div class="relative hidden lg:block">
          <div class="relative mx-auto max-w-sm">
            <!-- Phone Mockup -->
            <div class="bg-gray-900 rounded-[3rem] p-4 shadow-2xl">
              <div class="bg-white rounded-[2.5rem] overflow-hidden">
                <!-- Status Bar -->
                <div class="bg-toyota-red h-8 flex items-center justify-between px-6">
                  <span class="text-white text-xs font-medium">9:41</span>
                  <div class="flex gap-1">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/>
                    </svg>
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/>
                    </svg>
                  </div>
                </div>
                
                <!-- App Content -->
                <div class="p-4 bg-gray-50 min-h-[28rem] flex flex-col">
                  <div class="text-center mb-4">
                    <div class="text-4xl font-bold text-toyota-red mb-1">SOS</div>
                    <div class="text-xs text-gray-500">Tap to report emergency</div>
                  </div>
                  
                  <div class="grid grid-cols-3 gap-2 mb-4">
                    <button class="bg-police text-white py-3 rounded-lg text-xs font-medium">Police</button>
                    <button class="bg-medical text-white py-3 rounded-lg text-xs font-medium">Ambulance</button>
                    <button class="bg-fire text-white py-3 rounded-lg text-xs font-medium">Fire</button>
                  </div>
                  
                  <div class="flex-1 bg-white rounded-lg p-3">
                    <div class="text-xs font-medium text-gray-500 mb-2">LIVE INCIDENTS NEAR YOU</div>
                    <div class="space-y-2">
                      <div class="bg-red-50 border border-red-100 rounded p-2">
                        <div class="text-xs font-medium text-critical">Medical Emergency</div>
                        <div class="text-xs text-gray-500">0.5 km away</div>
                      </div>
                      <div class="bg-amber-50 border border-amber-100 rounded p-2">
                        <div class="text-xs font-medium text-warning">Traffic Incident</div>
                        <div class="text-xs text-gray-500">1.2 km away</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Features Section -->
  <section class="py-20 lg:py-32 bg-white">
    <Container>
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Why Choose Red alert?
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Designed for the Filipino public, built with cutting-edge technology 
          to ensure fast, reliable emergency response.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <Card>
          <div class="w-12 h-12 bg-toyota-red/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-toyota-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">One-Tap Reporting</h3>
          <p class="text-gray-600">
            Report emergencies instantly with auto-location, photos, and description in seconds.
          </p>
        </Card>

        <Card>
          <div class="w-12 h-12 bg-police/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-police" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Live Tracking</h3>
          <p class="text-gray-600">
            See responder location and exact ETA in real-time on your phone.
          </p>
        </Card>

        <Card>
          <div class="w-12 h-12 bg-medical/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-medical" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">First Aider Network</h3>
          <p class="text-gray-600">
            Get automatic alerts to nearby medical professionals who can help immediately.
          </p>
        </Card>

        <Card>
          <div class="w-12 h-12 bg-fire/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-fire" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Verified Responders</h3>
          <p class="text-gray-600">
            All responders are verified through PhilID and supervisor approval.
          </p>
        </Card>

        <Card>
          <div class="w-12 h-12 bg-warning/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Multi-Agency Response</h3>
          <p class="text-gray-600">
            Automatically dispatch Police, Ambulance, and Fire based on emergency type.
          </p>
        </Card>

        <Card>
          <div class="w-12 h-12 bg-success/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Silent SOS</h3>
          <p class="text-gray-600">
            Discreet emergency alert using power button - perfect for dangerous situations.
          </p>
        </Card>
      </div>
    </Container>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-toyota-red">
    <Container>
      <div class="text-center">
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
          Ready to Stay Safe?
        </h2>
        <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
          Download the app and get instant access to emergency services across the Philippines.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button 
            variant="secondary" 
            size="lg" 
            href="#"
            class="bg-white text-toyota-red hover:bg-gray-100"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            Download for iOS
          </Button>
          <Button 
            variant="secondary" 
            size="lg" 
            href="#"
            class="bg-white text-toyota-red hover:bg-gray-100"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35zm13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27zm3.35-4.31c.34.27.59.69.59 1.19s-.22.9-.57 1.18l-2.29 1.32-2.5-2.5 2.5-2.5 2.27 1.31zM6.05 2.66l10.76 6.22-2.27 2.27L6.05 2.66z"/>
            </svg>
            Download for Android
          </Button>
        </div>
      </div>
    </Container>
  </section>
</Layout>
