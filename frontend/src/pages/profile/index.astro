---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppHeader from '../../components/app/AppHeader.astro';
import BottomNav from '../../components/app/BottomNav.astro';

// Middleware guarantees user + accessToken are set for /profile routes
const { user: sessionUser, accessToken } = Astro.locals;

interface EmergencyContact {
  name: string;
  relationship: string;
  phone: string;
}
interface UserProfile {
  id: string;
  phone: string;
  email: string;
  first_name: string;
  last_name: string;
  profile_image_url: string | null;
  is_verified: boolean;
  is_active: boolean;
  last_login_at: string | null;
  created_at: string;
  updated_at: string;
  roles: { id: string; name: string }[];
  emergency_contacts: EmergencyContact[];
}

let profile: UserProfile | null = null;
let fetchError: string | null = null;

if (!sessionUser) {
  fetchError = 'Session error: user info not available. Please sign out and sign in again.';
} else {
  try {
    const apiBase = import.meta.env.API_BASE_URL;
    const apiVersion = import.meta.env.API_VERSION ?? 'v1';
    const res = await fetch(`${apiBase}/${apiVersion}/users/${sessionUser.id}`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    if (res.ok) {
      profile = await res.json();
    } else {
      fetchError = res.status === 401 ? 'Session expired. Please sign in again.' : `Failed to load profile (${res.status}).`;
    }
  } catch (err) {
    fetchError = `Network error: ${err instanceof Error ? err.message : String(err)}`;
  }
}

const roleColors: Record<string, string> = {
  ADMIN:       'bg-purple-100 text-purple-800 border-purple-200',
  DISPATCHER:  'bg-blue-100 text-blue-800 border-blue-200',
  RESPONDER:   'bg-green-100 text-green-800 border-green-200',
  FIRST_AIDER: 'bg-yellow-100 text-yellow-800 border-yellow-200',
  CITIZEN:     'bg-gray-100 text-gray-700 border-gray-200',
};

function formatDate(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-PH', {
    year: 'numeric', month: 'long', day: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const initials = profile
  ? `${profile.first_name?.[0] ?? ''}${profile.last_name?.[0] ?? ''}`.toUpperCase() || '??'
  : '??';

const roles = profile?.roles ?? [];
const emergencyContacts = profile?.emergency_contacts ?? [];
---

<BaseLayout title="My Profile">
  <div class="min-h-screen bg-gray-50 flex flex-col md:pl-56">

  <AppHeader title="Profile">
    <a
      href="/api/auth/logout"
      title="Sign out"
      class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
    </a>
  </AppHeader>

  <main class="max-w-2xl mx-auto w-full px-4 pt-6 pb-24 space-y-5 flex-1">

    {fetchError && (
      <div class="flex items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <span>{fetchError}</span>
      </div>
    )}

    {profile && (
      <>
        <!-- Profile header card -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <!-- Banner -->
          <div class="h-24 bg-gradient-to-r from-toyota-red to-red-700"></div>

          <div class="px-6 pb-6">
            <!-- Avatar + status badges -->
            <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 -mt-12 mb-4">
              <div class="relative w-fit">
                {profile.profile_image_url ? (
                  <img
                    src={profile.profile_image_url}
                    alt={`${profile.first_name} ${profile.last_name}`}
                    class="w-24 h-24 rounded-2xl border-4 border-white shadow-md object-cover"
                  />
                ) : (
                  <div class="w-24 h-24 rounded-2xl border-4 border-white shadow-md bg-toyota-red flex items-center justify-center">
                    <span class="text-2xl font-bold text-white">{initials}</span>
                  </div>
                )}
                {profile.is_active && (
                  <span class="absolute bottom-1 right-1 w-4 h-4 bg-green-500 border-2 border-white rounded-full" title="Active"></span>
                )}
              </div>

              <div class="flex flex-wrap gap-2 sm:mb-1">
                <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium border ${profile.is_verified ? 'bg-blue-50 text-blue-700 border-blue-200' : 'bg-gray-50 text-gray-500 border-gray-200'}`}>
                  {profile.is_verified ? (
                    <>
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      Verified
                    </>
                  ) : 'Unverified'}
                </span>
                <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border ${profile.is_active ? 'bg-green-50 text-green-700 border-green-200' : 'bg-red-50 text-red-600 border-red-200'}`}>
                  {profile.is_active ? 'Active' : 'Inactive'}
                </span>
              </div>
            </div>

            <!-- Name and roles -->
            <div>
              <h1 class="text-2xl font-bold text-gray-900">{profile.first_name} {profile.last_name}</h1>
              <p class="text-gray-500 text-sm mt-0.5">{profile.email}</p>
              <div class="flex flex-wrap gap-2 mt-3">
                {roles.map(role => (
                  <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${roleColors[role.name] ?? roleColors.CITIZEN}`}>
                    {role.name}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Contact & account info -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Contact info -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Contact Information</h2>
            <dl class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <div>
                  <dt class="text-xs text-gray-400">Email</dt>
                  <dd class="text-sm font-medium text-gray-900">{profile.email}</dd>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <div>
                  <dt class="text-xs text-gray-400">Phone</dt>
                  <dd class="text-sm font-medium text-gray-900">{profile.phone}</dd>
                </div>
              </div>
            </dl>
          </div>

          <!-- Account info -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Account Details</h2>
            <dl class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                </svg>
                <div>
                  <dt class="text-xs text-gray-400">Last Login</dt>
                  <dd class="text-sm font-medium text-gray-900">{formatDate(profile.last_login_at)}</dd>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <div>
                  <dt class="text-xs text-gray-400">Member Since</dt>
                  <dd class="text-sm font-medium text-gray-900">{formatDate(profile.created_at)}</dd>
                </div>
              </div>
            </dl>
          </div>
        </div>

        <!-- Emergency Contacts -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Emergency Contacts</h2>
            <a href="/profile/emergency-contacts" class="text-xs text-toyota-red font-medium hover:underline">Manage</a>
          </div>

          {emergencyContacts.length === 0 ? (
            <div class="text-center py-8 text-gray-400">
              <svg class="w-10 h-10 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <p class="text-sm">No emergency contacts added</p>
            </div>
          ) : (
            <ul class="divide-y divide-gray-100">
              {emergencyContacts.map(contact => (
                <li class="flex items-center justify-between py-4 first:pt-0 last:pb-0">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-full bg-toyota-red/10 flex items-center justify-center shrink-0">
                      <svg class="w-5 h-5 text-toyota-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                      </svg>
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-gray-900">{contact.name}</p>
                      <p class="text-xs text-gray-500">{contact.relationship}</p>
                    </div>
                  </div>
                  <a
                    href={`tel:${contact.phone}`}
                    class="flex items-center gap-1.5 text-sm text-toyota-red font-medium hover:text-toyota-red-dark transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    {contact.phone}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </>
    )}
  </main>

  <BottomNav active="profile" />
  </div>
</BaseLayout>
