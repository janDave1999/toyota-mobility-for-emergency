---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppHeader from '../../components/app/AppHeader.astro';
import BottomNav from '../../components/app/BottomNav.astro';

const { user: sessionUser, accessToken } = Astro.locals;

interface EmergencyContact {
  id: string;
  name: string;
  phone: string;
  relationship: string;
}

let contacts: EmergencyContact[] = [];
let fetchError: string | null = null;

if (!sessionUser) {
  fetchError = 'Session error: user info not available. Please sign out and sign in again.';
} else {
  try {
    const apiBase = import.meta.env.API_BASE_URL;
    const res = await fetch(`${apiBase}api/users/${sessionUser.id}/emergency-contacts`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    if (res.ok) {
      const json = await res.json();
      contacts = json.data ?? json ?? [];
    } else {
      fetchError = res.status === 401 ? 'Session expired. Please sign in again.' : `Failed to load contacts (${res.status}).`;
    }
  } catch (err) {
    fetchError = `Network error: ${err instanceof Error ? err.message : String(err)}`;
  }
}

const RELATIONSHIPS = ['Spouse', 'Parent', 'Child', 'Sibling', 'Friend', 'Colleague', 'Neighbor', 'Other'];
---

<BaseLayout title="Emergency Contacts">
  <div class="min-h-screen bg-gray-50 flex flex-col md:pl-56">

  <AppHeader title="Emergency Contacts" back={{ href: '/profile', label: 'Profile' }}>
    <button
      id="btn-add"
      class="flex items-center gap-1.5 px-3 py-1.5 bg-toyota-red text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add
    </button>
  </AppHeader>

  <main class="max-w-2xl mx-auto w-full px-4 py-6 pb-24 flex-1">

    {fetchError && (
      <div class="flex items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <span>{fetchError}</span>
      </div>
    )}

    <!-- Toast -->
    <div id="toast" style="display:none" class="fixed top-4 right-4 z-50 flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white min-w-64 max-w-sm">
      <svg id="toast-icon" class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"></svg>
      <span id="toast-msg"></span>
    </div>

    <!-- Contacts list -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Contacts</h2>
        <span id="count-badge" class="text-xs text-gray-400">{contacts.length} contact{contacts.length !== 1 ? 's' : ''}</span>
      </div>

      <ul id="contacts-list" class="divide-y divide-gray-100">
        {contacts.length === 0 && !fetchError && (
          <li id="empty-state" class="py-16 text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm font-medium">No emergency contacts yet</p>
            <p class="text-xs mt-1">Add someone who should be notified in an emergency</p>
          </li>
        )}
        {contacts.map(contact => (
          <li
            class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors"
            data-id={contact.id}
            data-name={contact.name}
            data-phone={contact.phone}
            data-relationship={contact.relationship}
          >
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-toyota-red/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-toyota-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">{contact.name}</p>
                <p class="text-xs text-gray-500">{contact.relationship} · {contact.phone}</p>
              </div>
            </div>
            <div class="flex items-center gap-1">
              <a
                href={`tel:${contact.phone}`}
                class="p-2 text-gray-400 hover:text-toyota-red hover:bg-red-50 rounded-lg transition-colors"
                title="Call"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </a>
              <button
                class="btn-edit p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
                title="Edit"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              </button>
              <button
                class="btn-delete p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"
                title="Delete"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              </button>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </main>

  <!-- Add / Edit Modal -->
  <div id="modal-form" style="display:none" class="fixed inset-0 z-40 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-form-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-5">
        <h3 id="modal-form-title" class="text-lg font-semibold text-gray-900">Add Contact</h3>
        <button id="modal-form-close" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Form error -->
      <div id="form-error" style="display:none" class="flex items-start gap-2 p-3 mb-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <span id="form-error-msg"></span>
      </div>

      <form id="contact-form" novalidate class="space-y-4">
        <input type="hidden" id="field-id" value="" />

        <div>
          <label for="field-name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <input
            type="text" id="field-name" placeholder="e.g. Maria Dela Cruz"
            class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-toyota-red focus:border-transparent transition"
          />
        </div>

        <div>
          <label for="field-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
          <input
            type="tel" id="field-phone" placeholder="0917 123 4567" maxlength="13"
            class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-toyota-red focus:border-transparent transition"
          />
          <p id="phone-hint" class="mt-1 text-xs text-gray-400">Format: 09XX XXX XXXX</p>
          <p id="phone-error" class="mt-1 text-xs text-red-500 hidden"></p>
        </div>

        <div>
          <label for="field-relationship" class="block text-sm font-medium text-gray-700 mb-1">Relationship</label>
          <select
            id="field-relationship"
            class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-toyota-red focus:border-transparent transition bg-white"
          >
            <option value="">Select relationship</option>
            {RELATIONSHIPS.map(r => <option value={r}>{r}</option>)}
          </select>
        </div>

        <div class="flex gap-3 pt-2">
          <button
            type="button" id="modal-form-cancel"
            class="flex-1 px-4 py-2.5 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
          >
            Cancel
          </button>
          <button
            type="submit" id="form-submit"
            class="flex-1 px-4 py-2.5 text-sm font-medium text-white bg-toyota-red hover:bg-red-700 rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Save
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="modal-delete" style="display:none" class="fixed inset-0 z-40 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-delete-backdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-sm p-6">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-gray-900">Remove Contact</h3>
          <p class="text-sm text-gray-500">This action cannot be undone.</p>
        </div>
      </div>
      <p class="text-sm text-gray-700 mb-5">
        Are you sure you want to remove <strong id="delete-name"></strong> from your emergency contacts?
      </p>
      <div class="flex gap-3">
        <button
          id="modal-delete-cancel"
          class="flex-1 px-4 py-2.5 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
        >
          Cancel
        </button>
        <button
          id="btn-confirm-delete"
          class="flex-1 px-4 py-2.5 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Remove
        </button>
      </div>
    </div>
  </div>

  <BottomNav active="profile" />
  </div>
</BaseLayout>

<script>
import { actions, isInputError } from 'astro:actions';

// ── Helpers ──────────────────────────────────────────────────────────────────

function showToast(msg: string, type: 'success' | 'error') {
  const toast = document.getElementById('toast')!;
  const icon  = document.getElementById('toast-icon')!;
  const text  = document.getElementById('toast-msg')!;
  toast.className = `fixed top-4 right-4 z-50 flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium text-white min-w-64 max-w-sm ${type === 'success' ? 'bg-green-600' : 'bg-red-600'}`;
  icon.innerHTML = type === 'success'
    ? '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>'
    : '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>';
  text.textContent = msg;
  toast.style.display = 'flex';
  setTimeout(() => { toast.style.display = 'none'; }, 3500);
}

function showFormError(msg: string) {
  const el = document.getElementById('form-error')!;
  document.getElementById('form-error-msg')!.textContent = msg;
  el.style.display = 'flex';
}

function clearFormError() {
  document.getElementById('form-error')!.style.display = 'none';
}

// ── Phone live formatting + validation (PH only) ──────────────────────────────

const phoneField = document.getElementById('field-phone') as HTMLInputElement;
const phoneErr   = document.getElementById('phone-error')!;
const phoneHint  = document.getElementById('phone-hint')!;

function parsePHPhone(raw: string): { valid: boolean; e164: string; error: string } {
  const cleaned = raw.replace(/[\s\-\(\)\.]/g, '');
  let digits = cleaned;
  if (digits.startsWith('+63')) digits = digits.slice(3);
  else if (digits.startsWith('63') && digits.length > 10) digits = digits.slice(2);
  if (digits.startsWith('0')) digits = digits.slice(1);
  if (!/^9\d{9}$/.test(digits)) {
    return { valid: false, e164: '', error: 'Enter a valid PH mobile number (e.g. 0917 123 4567).' };
  }
  return { valid: true, e164: `+63${digits}`, error: '' };
}

function formatPHLive(raw: string): string {
  let digits = raw.replace(/\D/g, '');
  if (digits.startsWith('63')) digits = '0' + digits.slice(2);
  else if (!digits.startsWith('0') && digits.startsWith('9')) digits = '0' + digits;
  digits = digits.slice(0, 11);
  const p1 = digits.slice(0, 4);
  const p2 = digits.slice(4, 7);
  const p3 = digits.slice(7, 11);
  let out = p1;
  if (p2) out += ' ' + p2;
  if (p3) out += ' ' + p3;
  return out;
}

function setPhoneBorder(state: 'neutral' | 'valid' | 'invalid') {
  phoneField.classList.remove('border-gray-300', 'border-green-500', 'border-red-400');
  phoneField.classList.add(state === 'valid' ? 'border-green-500' : state === 'invalid' ? 'border-red-400' : 'border-gray-300');
}

function validatePhoneField(showError = false) {
  const { valid, error } = parsePHPhone(phoneField.value.trim());
  if (valid) {
    phoneErr.classList.add('hidden');
    phoneHint.classList.add('hidden');
    setPhoneBorder('valid');
  } else if (showError && phoneField.value.trim()) {
    phoneErr.textContent = error;
    phoneErr.classList.remove('hidden');
    phoneHint.classList.add('hidden');
    setPhoneBorder('invalid');
  } else {
    phoneErr.classList.add('hidden');
    phoneHint.classList.remove('hidden');
    setPhoneBorder('neutral');
  }
  return valid;
}

function resetPhoneField() {
  phoneErr.classList.add('hidden');
  phoneHint.classList.remove('hidden');
  setPhoneBorder('neutral');
}

phoneField.addEventListener('input', () => {
  const cursor = phoneField.selectionStart ?? 0;
  const prevLen = phoneField.value.length;
  const formatted = formatPHLive(phoneField.value);
  phoneField.value = formatted;
  const diff = formatted.length - prevLen;
  phoneField.setSelectionRange(cursor + diff, cursor + diff);
  validatePhoneField(false);
});

phoneField.addEventListener('keydown', (e: KeyboardEvent) => {
  const allowed = ['Backspace','Delete','ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Tab','Home','End'];
  if (allowed.includes(e.key) || e.ctrlKey || e.metaKey) return;
  if (!/^\d$/.test(e.key)) e.preventDefault();
});

phoneField.addEventListener('blur', () => validatePhoneField(true));

// ── Modal helpers ─────────────────────────────────────────────────────────────

function openFormModal(mode: 'add' | 'edit', data?: { id: string; name: string; phone: string; relationship: string }) {
  clearFormError();
  resetPhoneField();
  const title  = document.getElementById('modal-form-title')!;
  const submit = document.getElementById('form-submit') as HTMLButtonElement;
  title.textContent  = mode === 'add' ? 'Add Contact' : 'Edit Contact';
  submit.textContent = mode === 'add' ? 'Add' : 'Save Changes';

  (document.getElementById('field-id') as HTMLInputElement).value            = data?.id ?? '';
  (document.getElementById('field-name') as HTMLInputElement).value          = data?.name ?? '';
  // Format existing phone for display when editing
  phoneField.value = data?.phone ? formatPHLive(data.phone) : '';
  if (data?.phone) validatePhoneField(false);
  (document.getElementById('field-relationship') as HTMLSelectElement).value = data?.relationship ?? '';

  document.getElementById('modal-form')!.style.display = 'flex';
}

function closeFormModal() {
  document.getElementById('modal-form')!.style.display = 'none';
}

let pendingDeleteId = '';

function openDeleteModal(id: string, name: string) {
  pendingDeleteId = id;
  document.getElementById('delete-name')!.textContent = name;
  document.getElementById('modal-delete')!.style.display = 'flex';
}

function closeDeleteModal() {
  document.getElementById('modal-delete')!.style.display = 'none';
  pendingDeleteId = '';
}

// ── Bind static buttons ───────────────────────────────────────────────────────

document.getElementById('btn-add')!.addEventListener('click', () => openFormModal('add'));
document.getElementById('modal-form-close')!.addEventListener('click', closeFormModal);
document.getElementById('modal-form-cancel')!.addEventListener('click', closeFormModal);
document.getElementById('modal-form-backdrop')!.addEventListener('click', closeFormModal);
document.getElementById('modal-delete-cancel')!.addEventListener('click', closeDeleteModal);
document.getElementById('modal-delete-backdrop')!.addEventListener('click', closeDeleteModal);

// ── Delegate edit/delete clicks ───────────────────────────────────────────────

document.getElementById('contacts-list')!.addEventListener('click', (e) => {
  const editBtn   = (e.target as Element).closest('.btn-edit');
  const deleteBtn = (e.target as Element).closest('.btn-delete');
  const row       = (e.target as Element).closest('[data-id]') as HTMLElement | null;
  if (!row) return;

  if (editBtn) {
    openFormModal('edit', {
      id:           row.dataset.id!,
      name:         row.dataset.name!,
      phone:        row.dataset.phone!,
      relationship: row.dataset.relationship!,
    });
  }

  if (deleteBtn) {
    openDeleteModal(row.dataset.id!, row.dataset.name!);
  }
});

// ── Form submit ───────────────────────────────────────────────────────────────

document.getElementById('contact-form')!.addEventListener('submit', async (e) => {
  e.preventDefault();
  clearFormError();

  const id           = (document.getElementById('field-id') as HTMLInputElement).value.trim();
  const name         = (document.getElementById('field-name') as HTMLInputElement).value.trim();
  const relationship = (document.getElementById('field-relationship') as HTMLSelectElement).value;
  const submitBtn    = document.getElementById('form-submit') as HTMLButtonElement;

  if (!name || !phoneField.value.trim() || !relationship) {
    showFormError('Please fill in all fields.');
    return;
  }

  const phoneResult = parsePHPhone(phoneField.value.trim());
  if (!phoneResult.valid) {
    validatePhoneField(true);
    showFormError(phoneResult.error);
    return;
  }
  const phone = phoneResult.e164;

  submitBtn.disabled = true;
  submitBtn.textContent = 'Saving…';

  const isEdit = !!id;
  const result = isEdit
    ? await actions.emergencyContacts.update({ id, name, phone, relationship })
    : await actions.emergencyContacts.add({ name, phone, relationship });

  submitBtn.disabled = false;
  submitBtn.textContent = isEdit ? 'Save Changes' : 'Add';

  if (result.error) {
    const msg = isInputError(result.error)
      ? Object.values(result.error.fields).flat()[0] ?? 'Validation error.'
      : result.error.message;
    showFormError(msg);
    return;
  }

  closeFormModal();
  showToast(isEdit ? 'Contact updated.' : 'Contact added.', 'success');
  setTimeout(() => window.location.reload(), 800);
});

// ── Delete confirm ─────────────────────────────────────────────────────────────

document.getElementById('btn-confirm-delete')!.addEventListener('click', async () => {
  if (!pendingDeleteId) return;
  const btn = document.getElementById('btn-confirm-delete') as HTMLButtonElement;
  btn.disabled = true;
  btn.textContent = 'Removing…';

  const result = await actions.emergencyContacts.delete({ id: pendingDeleteId });

  btn.disabled = false;
  btn.textContent = 'Remove';

  if (result.error) {
    closeDeleteModal();
    showToast(result.error.message ?? 'Failed to delete contact.', 'error');
    return;
  }

  closeDeleteModal();
  showToast('Contact removed.', 'success');
  setTimeout(() => window.location.reload(), 800);
});
</script>
