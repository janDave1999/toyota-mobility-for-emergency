---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { Button } from '../../components';

interface Props {
  phone: string;
  purpose: 'register' | 'login';
}

const { phone = '+63 912 345 6789', purpose = 'register' } = Astro.props;
---

<AuthLayout title="Verify Phone">
  <div class="text-center">
    <div class="mx-auto w-16 h-16 bg-toyota-red/10 rounded-full flex items-center justify-center mb-4">
      <svg class="w-8 h-8 text-toyota-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-gray-900">Verify your phone</h1>
    <p class="mt-2 text-gray-600">
      We sent a 6-digit code to<br/>
      <span class="font-medium text-gray-900">{phone}</span>
    </p>
  </div>

  <form class="mt-8 space-y-6" action="/api/auth/verify" method="POST">
    <input type="hidden" name="phone" value={phone} />
    <input type="hidden" name="purpose" value={purpose} />

    <div class="flex justify-center gap-3">
      <input
        type="text"
        name="otp_1"
        maxlength="1"
        class="w-14 h-14 text-center text-xl font-bold rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 outline-none"
      />
      <input
        type="text"
        name="otp_2"
        maxlength="1"
        class="w-14 h-14 text-center text-xl font-bold rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 outline-none"
      />
      <input
        type="text"
        name="otp_3"
        maxlength="1"
        class="w-14 h-14 text-center text-xl font-bold rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 outline-none"
      />
      <input
        type="text"
        name="otp_4"
        maxlength="1"
        class="w-14 h-14 text-center text-xl font-bold rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 outline-none"
      />
      <input
        type="text"
        name="otp_5"
        maxlength="1"
        class="w-14 h-14 text-center text-xl font-bold rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 outline-none"
      />
      <input
        type="text"
        name="otp_6"
        maxlength="1"
        class="w-14 h-14 text-center text-xl font-bold rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 outline-none"
      />
    </div>

    <Button type="submit" fullWidth size="lg">
      Verify
    </Button>
  </form>

  <div class="mt-6 text-center">
    <p class="text-sm text-gray-600">
      Didn't receive the code?
    </p>
    <button
      type="button"
      class="mt-2 text-sm font-medium text-toyota-red hover:text-toyota-red-dark"
    >
      Resend code (59s)
    </button>
  </div>

  <p class="mt-8 text-center text-sm text-gray-600">
    <a href={purpose === 'register' ? '/auth/register' : '/auth/login'} class="font-medium text-toyota-red hover:text-toyota-red-dark">
      Change phone number
    </a>
  </p>
</AuthLayout>

<script>
  const inputs = document.querySelectorAll('input[name^="otp_"]');
  
  inputs.forEach((input, index) => {
    input.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.value.length === 1 && index < inputs.length - 1) {
        (inputs[index + 1] as HTMLInputElement).focus();
      }
    });
    
    input.addEventListener('keydown', (e) => {
      const target = e.target as HTMLInputElement;
      if (e.key === 'Backspace' && target.value.length === 0 && index > 0) {
        (inputs[index - 1] as HTMLInputElement).focus();
      }
    });
  });
</script>
