---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { Button, Turnstile } from '../../components';

const errorParam = Astro.url.searchParams.get('error');
const serverErrorMessage = errorParam === 'session_expired'
  ? 'Your session expired. Please sign in again.'
  : null;
---

<AuthLayout title="Sign In">
  <div class="text-center">
    <h1 class="text-2xl font-bold text-gray-900">Welcome back</h1>
    <p class="mt-2 text-gray-600">Sign in to your account</p>
  </div>

  {serverErrorMessage && (
    <div class="mt-4 flex items-start gap-3 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span>{serverErrorMessage}</span>
    </div>
  )}

  <form class="mt-8 space-y-5" id="login-form" novalidate>
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
        Email Address
      </label>
      <input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="juan@example.com"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
      />
    </div>

    <div>
      <div class="flex items-center justify-between mb-1">
        <label for="password" class="block text-sm font-medium text-gray-700">
          Password
        </label>
        <a href="/auth/forgot-password" class="text-xs text-toyota-red hover:text-toyota-red-dark font-medium">
          Forgot password?
        </a>
      </div>
      <div class="relative">
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          placeholder="Enter your password"
          class="w-full px-4 py-3 pr-12 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
        />
        <button
          type="button"
          id="toggle-password"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors"
          aria-label="Toggle password visibility"
        >
          <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          <svg id="eye-off-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
          </svg>
        </button>
      </div>
    </div>

    <Turnstile id="login-turnstile" action="login" theme="light" />

    <!-- Error: no flex here — JS toggles display via style -->
    <div id="form-error" style="display:none" class="items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span id="form-error-message"></span>
    </div>

    <div id="submit-wrapper">
      <Button type="submit" fullWidth size="lg">
        Sign In
      </Button>
    </div>
  </form>

  <p class="mt-6 text-center text-sm text-gray-600">
    Don't have an account?{' '}
    <a href="/auth/register" class="font-medium text-toyota-red hover:text-toyota-red-dark">
      Sign up for free
    </a>
  </p>
</AuthLayout>

<script>
  import { actions, isInputError } from 'astro:actions';

  declare global {
    interface Window {
      turnstile?: { reset: (selector: string) => void };
    }
  }

  let turnstileToken = '';

  function showFormError(message: string) {
    const errorEl = document.getElementById('form-error')!;
    document.getElementById('form-error-message')!.textContent = message;
    errorEl.style.display = 'flex';
  }

  function clearFormError() {
    const errorEl = document.getElementById('form-error');
    if (errorEl) errorEl.style.display = 'none';
  }

  document.addEventListener('turnstile:success', (e) => {
    turnstileToken = (e as CustomEvent<{ token: string }>).detail.token;
    clearFormError();
  });
  document.addEventListener('turnstile:expired', () => { turnstileToken = ''; });
  document.addEventListener('turnstile:error', () => { turnstileToken = ''; });

  document.getElementById('toggle-password')?.addEventListener('click', () => {
    const input = document.getElementById('password') as HTMLInputElement;
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    document.getElementById('eye-icon')?.classList.toggle('hidden', isHidden);
    document.getElementById('eye-off-icon')?.classList.toggle('hidden', !isHidden);
  });

  document.getElementById('email')?.addEventListener('input', clearFormError);
  document.getElementById('password')?.addEventListener('input', clearFormError);

  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearFormError();

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const submitBtn = document.querySelector<HTMLButtonElement>('#submit-wrapper button')!;

    if (!email || !password) {
      showFormError('Please enter your email and password.');
      return;
    }

    if (!turnstileToken) {
      showFormError('Please complete the security check.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Signing in…';

    try {
      const result = await actions.auth.login({ email, password, turnstileToken });

      if (result.error) {
        const message = isInputError(result.error)
          ? Object.values(result.error.fields).flat()[0] ?? 'Please check your input.'
          : result.error.message;
        showFormError(message ?? 'Invalid email or password.');
        window.turnstile?.reset('#login-turnstile');
        turnstileToken = '';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Sign In';
        return;
      }

      window.location.href = result.data.redirect;
    } catch {
      showFormError('Network error. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Sign In';
    }
  });
</script>
