---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { Button, Turnstile } from '../../components';
---

<AuthLayout title="Create Account">
  <div class="text-center">
    <h1 class="text-2xl font-bold text-gray-900">Create an account</h1>
    <p class="mt-2 text-gray-600">Join Toyota Mobility for Emergency</p>
  </div>

  <form class="mt-8 space-y-5" id="register-form">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1">
          First Name
        </label>
        <input
          id="first_name"
          name="first_name"
          type="text"
          required
          placeholder="Juan"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
        />
      </div>
      <div>
        <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1">
          Last Name
        </label>
        <input
          id="last_name"
          name="last_name"
          type="text"
          required
          placeholder="Dela Cruz"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
        />
      </div>
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
        Phone Number
      </label>
      <div class="flex gap-2">
        <!-- Country selector (PH only for now) -->
        <select
          id="country-code"
          class="shrink-0 px-3 py-3 rounded-lg border border-gray-300 bg-white text-sm text-gray-700 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
        >
          <option value="+63">🇵🇭 +63</option>
        </select>
        <input
          id="phone"
          name="phone"
          type="tel"
          required
          placeholder="0917 123 4567"
          maxlength="13"
          class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
        />
      </div>
      <p id="phone-hint" class="mt-1 text-xs text-gray-400">Format: 09XX XXX XXXX or 9XX XXX XXXX</p>
      <p id="phone-error" class="mt-1 text-xs text-red-500 hidden"></p>
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
        Email Address
      </label>
      <input
        id="email"
        name="email"
        type="email"
        required
        placeholder="juan@example.com"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
      />
      <p id="email-error" class="mt-1 text-xs text-red-500 hidden"></p>
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
        Password
      </label>
      <div class="relative">
        <input
          id="password"
          name="password"
          type="password"
          required
          placeholder="Create a strong password"
          class="w-full px-4 py-3 pr-32 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
        />
        <div class="absolute right-1 top-1/2 -translate-y-1/2 flex gap-1 pr-2">
          <button
            type="button"
            id="toggle-password-btn"
            class="p-1.5 text-gray-400 hover:text-gray-600 transition-colors"
            title="Show password"
          >
            <svg id="eye-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg id="eye-off-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
          <button
            type="button"
            id="generate-password-btn"
            class="px-2 py-1 text-xs font-medium text-toyota-red hover:bg-toyota-red/10 rounded transition-colors"
          >
            Generate
          </button>
        </div>
      </div>
      
      <!-- Password Requirements -->
      <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-1">
        <div id="req-length" class="flex items-center gap-1 text-xs text-gray-400">
          <span class="w-3.5">○</span> At least 8 characters
        </div>
        <div id="req-number" class="flex items-center gap-1 text-xs text-gray-400">
          <span class="w-3.5">○</span> Contains a number
        </div>
        <div id="req-letter" class="flex items-center gap-1 text-xs text-gray-400">
          <span class="w-3.5">○</span> Contains a letter
        </div>
        <div id="req-special" class="flex items-center gap-1 text-xs text-gray-400">
          <span class="w-3.5">○</span> Special character (!@#$%)
        </div>
      </div>
    </div>

    <div>
      <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">
        Confirm Password
      </label>
      <input
        id="confirm_password"
        name="confirm_password"
        type="password"
        required
        placeholder="Confirm your password"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-toyota-red focus:ring-2 focus:ring-toyota-red/20 transition-colors outline-none"
      />
      <p id="match-text" class="mt-1 text-xs text-gray-500 hidden">
        <span id="match-icon"></span>
        <span id="match-message"></span>
      </p>
    </div>

    <div>
      <label for="file" class="block text-sm font-medium text-gray-700 mb-1">
        Profile Photo <span class="text-gray-400 font-normal">(optional)</span>
      </label>
      
      <!-- Preview Container -->
      <div id="preview-container" class="hidden mb-4">
        <div class="relative inline-block">
          <img id="preview-image" src="" alt="Preview" class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-lg" />
          <button
            type="button"
            id="remove-photo-btn"
            class="absolute -top-1 -right-1 bg-red-500 text-white rounded-full p-1.5 shadow-md hover:bg-red-600 transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <p id="preview-filename" class="mt-2 text-xs text-gray-500"></p>
      </div>
      
      <!-- Upload Area -->
      <div id="upload-area" class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-toyota-red transition-colors cursor-pointer">
        <div class="space-y-1 text-center">
          <svg id="upload-icon" class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div class="flex text-sm text-gray-600 justify-center">
            <label for="file-upload" class="relative cursor-pointer rounded-md font-medium text-toyota-red hover:text-toyota-red-dark">
              <span>Upload a file</span>
              <input id="file-upload" name="file" type="file" class="sr-only" accept="image/*" />
            </label>
            <p class="pl-1">or drag and drop</p>
          </div>
          <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
        </div>
      </div>
    </div>

    <div class="flex items-start">
      <input
        id="terms"
        name="terms"
        type="checkbox"
        required
        class="w-4 h-4 mt-0.5 rounded border-gray-300 text-toyota-red focus:ring-toyota-red"
      />
      <label for="terms" class="ml-2 text-sm text-gray-600">
        I agree to the{' '}
        <a href="/terms" class="text-toyota-red hover:text-toyota-red-dark font-medium">Terms of Service</a>
        {' '}and{' '}
        <a href="/privacy" class="text-toyota-red hover:text-toyota-red-dark font-medium">Privacy Policy</a>
      </label>
    </div>

    <div id="form-error" class="hidden flex items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
      <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span id="form-error-message"></span>
    </div>

    <Turnstile id="register-turnstile" />

    <Button type="submit" fullWidth size="lg">
      Create Account
    </Button>
  </form>

  <p class="mt-8 text-center text-sm text-gray-600">
    Already have an account?{' '}
    <a href="/auth/login" class="font-medium text-toyota-red hover:text-toyota-red-dark">
      Sign in
    </a>
  </p>
</AuthLayout>

<script>
  export {}; // make this a module so `declare global` is valid

  declare global {
    interface Window {
      turnstile?: { reset: (selector: string) => void };
    }
  }

  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const confirmInput = document.getElementById('confirm_password') as HTMLInputElement;
  const matchText = document.getElementById('match-text');
  const matchIcon = document.getElementById('match-icon');
  const matchMessage = document.getElementById('match-message');

  function checkPasswordRequirements(password: string) {
    return {
      length: password.length >= 8,
      number: /\d/.test(password),
      letter: /[a-zA-Z]/.test(password),
      special: /[!@#$%^&*]/.test(password),
    };
  }

  function updateRequirements(password: string) {
    const reqs = checkPasswordRequirements(password);
    const activeClass = 'text-green-500';
    const inactiveClass = 'text-gray-400';
    
    const reqLength = document.getElementById('req-length');
    const reqNumber = document.getElementById('req-number');
    const reqLetter = document.getElementById('req-letter');
    const reqSpecial = document.getElementById('req-special');
    
    if (reqLength) {
      reqLength.className = `flex items-center gap-1 text-xs ${reqs.length ? activeClass : inactiveClass}`;
      reqLength.querySelector('span')!.textContent = reqs.length ? '✓' : '○';
    }
    if (reqNumber) {
      reqNumber.className = `flex items-center gap-1 text-xs ${reqs.number ? activeClass : inactiveClass}`;
      reqNumber.querySelector('span')!.textContent = reqs.number ? '✓' : '○';
    }
    if (reqLetter) {
      reqLetter.className = `flex items-center gap-1 text-xs ${reqs.letter ? activeClass : inactiveClass}`;
      reqLetter.querySelector('span')!.textContent = reqs.letter ? '✓' : '○';
    }
    if (reqSpecial) {
      reqSpecial.className = `flex items-center gap-1 text-xs ${reqs.special ? activeClass : inactiveClass}`;
      reqSpecial.querySelector('span')!.textContent = reqs.special ? '✓' : '○';
    }
    
    return Object.values(reqs).filter(Boolean).length;
  }

  function checkPasswordMatch() {
    const password = passwordInput.value;
    const confirm = confirmInput.value;
    
    if (confirm.length === 0) {
      matchText?.classList.add('hidden');
      return;
    }
    
    matchText?.classList.remove('hidden');
    
    if (password === confirm) {
      matchIcon!.textContent = '✓';
      matchMessage!.textContent = 'Passwords match';
      matchMessage!.className = 'text-green-500';
    } else {
      matchIcon!.textContent = '✗';
      matchMessage!.textContent = 'Passwords do not match';
      matchMessage!.className = 'text-red-500';
    }
  }

  function generatePassword() {
    const chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*';
    let password = '';
    
    password += 'abcdefghijklmnopqrstuvwxyz'[Math.floor(Math.random() * 26)];
    password += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'[Math.floor(Math.random() * 26)];
    password += '0123456789'[Math.floor(Math.random() * 10)];
    password += '!@#$%^&*'[Math.floor(Math.random() * 8)];
    
    for (let i = 4; i < 16; i++) {
      password += chars[Math.floor(Math.random() * chars.length)];
    }
    
    password = password.split('').sort(() => Math.random() - 0.5).join('');
    
    passwordInput.value = password;
    confirmInput.value = password;
    updateRequirements(password);
    checkPasswordMatch();
    
    // Show password temporarily and copy to clipboard
    passwordInput.type = 'text';
    navigator.clipboard.writeText(password).then(() => {
      showToast('Password generated and copied to clipboard!');
    });
    
    setTimeout(() => {
      passwordInput.type = 'password';
    }, 3000);
  }

  function showToast(message: string, type: 'success' | 'error' | 'warning' | 'info' = 'info') {
    const existing = document.getElementById('toast');
    if (existing) existing.remove();

    const styles = {
      success: 'bg-green-500 border-green-600',
      error:   'bg-red-500 border-red-600',
      warning: 'bg-yellow-500 border-yellow-600',
      info:    'bg-blue-500 border-blue-600',
    };
    const icons = {
      success: '✓',
      error:   '✕',
      warning: '⚠',
      info:    'ℹ',
    };

    const toast = document.createElement('div');
    toast.id = 'toast';
    toast.className = `fixed top-4 right-4 flex items-center gap-2 ${styles[type]} text-white px-4 py-3 rounded-lg shadow-lg text-sm z-50 border-l-4 animate-toast-in max-w-xs`;
    toast.innerHTML = `<span class="font-bold text-base leading-none">${icons[type]}</span><span>${message}</span>`;
    document.body.appendChild(toast);

    setTimeout(() => {
      toast.remove();
    }, 3500);
  }

  // Toggle password visibility
  document.getElementById('toggle-password-btn')?.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    document.getElementById('eye-icon')?.classList.toggle('hidden', isPassword);
    document.getElementById('eye-off-icon')?.classList.toggle('hidden', !isPassword);
  });

  passwordInput?.addEventListener('input', (e) => {
    updateRequirements((e.target as HTMLInputElement).value);
    checkPasswordMatch();
    clearFormError();
  });

  confirmInput?.addEventListener('input', () => {
    checkPasswordMatch();
    clearFormError();
  });

  document.getElementById('generate-password-btn')?.addEventListener('click', generatePassword);

  // File upload preview
  const fileInput = document.getElementById('file-upload') as HTMLInputElement;
  const previewContainer = document.getElementById('preview-container');
  const previewImage = document.getElementById('preview-image') as HTMLImageElement;
  const previewFilename = document.getElementById('preview-filename');
  const uploadArea = document.getElementById('upload-area');
  const removePhotoBtn = document.getElementById('remove-photo-btn');

  fileInput?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) {
      if (!file.type.startsWith('image/')) {
        showToast('Please select an image file', 'error');
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        showToast('File size must be less than 10MB', 'error');
        return;
      }
      
      const reader = new FileReader();
      reader.onload = (e) => {
        previewImage.src = e.target?.result as string;
        previewContainer?.classList.remove('hidden');
        uploadArea?.classList.add('hidden');
        if (previewFilename) {
          previewFilename.textContent = file.name;
        }
      };
      reader.readAsDataURL(file);
    }
  });

  removePhotoBtn?.addEventListener('click', () => {
    fileInput.value = '';
    previewImage.src = '';
    previewContainer?.classList.add('hidden');
    uploadArea?.classList.remove('hidden');
    if (previewFilename) {
      previewFilename.textContent = '';
    }
  });

  let turnstileToken = '';
  document.addEventListener('turnstile:success', (e: Event) => {
    turnstileToken = (e as CustomEvent<{ token: string }>).detail.token;
  });
  document.addEventListener('turnstile:expired', () => { turnstileToken = ''; });
  document.addEventListener('turnstile:error', () => { turnstileToken = ''; });

  function showFormError(message: string) {
    const errorEl = document.getElementById('form-error')!;
    const msgEl = document.getElementById('form-error-message')!;
    msgEl.textContent = message;
    errorEl.classList.remove('hidden');
    errorEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function clearFormError() {
    document.getElementById('form-error')?.classList.add('hidden');
  }

  // ── Phone validation + live formatting (PH only) ────────────────────────────

  function parsePHPhone(raw: string): { valid: boolean; e164: string; error: string } {
    const cleaned = raw.replace(/[\s\-\(\)\.]/g, '');
    let digits = cleaned;
    if (digits.startsWith('+63')) digits = digits.slice(3);
    else if (digits.startsWith('63') && digits.length > 10) digits = digits.slice(2);
    if (digits.startsWith('0')) digits = digits.slice(1);
    if (!/^9\d{9}$/.test(digits)) {
      return { valid: false, e164: '', error: 'Enter a valid PH mobile number (e.g. 0917 123 4567).' };
    }
    return { valid: true, e164: `+63${digits}`, error: '' };
  }

  // Formats a digit string into "0XXX XXX XXXX" as the user types
  function formatPHLive(raw: string): string {
    // Strip everything except digits
    let digits = raw.replace(/\D/g, '');

    // Normalise to local format (leading 0 + 10 subscriber digits)
    if (digits.startsWith('63')) digits = '0' + digits.slice(2);
    else if (!digits.startsWith('0') && digits.startsWith('9')) digits = '0' + digits;

    // Cap at 11 digits (0 + 10)
    digits = digits.slice(0, 11);

    // Apply mask: 0XXX XXX XXXX
    const p1 = digits.slice(0, 4);          // 0917
    const p2 = digits.slice(4, 7);          // 123
    const p3 = digits.slice(7, 11);         // 4567
    let out = p1;
    if (p2) out += ' ' + p2;
    if (p3) out += ' ' + p3;
    return out;
  }

  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  const phoneError = document.getElementById('phone-error')!;
  const phoneHint  = document.getElementById('phone-hint')!;

  function validatePhone(showError = false) {
    const { valid, error } = parsePHPhone(phoneInput.value.trim());
    if (!valid && showError && phoneInput.value.trim()) {
      phoneError.textContent = error;
      phoneError.classList.remove('hidden');
      phoneHint.classList.add('hidden');
      phoneInput.classList.add('border-red-400');
      phoneInput.classList.remove('border-gray-300', 'border-green-500');
    } else if (valid) {
      phoneError.classList.add('hidden');
      phoneHint.classList.add('hidden');
      phoneInput.classList.remove('border-red-400', 'border-gray-300');
      phoneInput.classList.add('border-green-500');
    } else {
      phoneError.classList.add('hidden');
      phoneHint.classList.remove('hidden');
      phoneInput.classList.remove('border-red-400', 'border-green-500');
      phoneInput.classList.add('border-gray-300');
    }
    return valid;
  }

  phoneInput?.addEventListener('input', () => {
    const cursor = phoneInput.selectionStart ?? 0;
    const prevLen = phoneInput.value.length;
    const formatted = formatPHLive(phoneInput.value);
    phoneInput.value = formatted;
    // Restore cursor, accounting for added spaces
    const diff = formatted.length - prevLen;
    phoneInput.setSelectionRange(cursor + diff, cursor + diff);
    validatePhone(false);
  });

  // Prevent non-numeric keys (allow control keys)
  phoneInput?.addEventListener('keydown', (e: KeyboardEvent) => {
    const allowed = ['Backspace','Delete','ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Tab','Home','End'];
    if (allowed.includes(e.key) || e.ctrlKey || e.metaKey) return;
    if (!/^\d$/.test(e.key)) e.preventDefault();
  });

  phoneInput?.addEventListener('blur', () => validatePhone(true));

  // ── Email live validation ────────────────────────────────────────────────────

  const emailInput = document.getElementById('email') as HTMLInputElement;
  const emailError = document.getElementById('email-error')!;

  function isValidEmail(value: string): boolean {
    // RFC-ish: local@domain.tld — rejects obvious typos
    return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value.trim());
  }

  function validateEmail(showError = false) {
    const value = emailInput.value.trim();
    const valid = isValidEmail(value);
    if (valid) {
      emailError.classList.add('hidden');
      emailInput.classList.remove('border-red-400', 'border-gray-300');
      emailInput.classList.add('border-green-500');
    } else if (showError && value) {
      emailError.textContent = 'Enter a valid email address (e.g. juan@example.com).';
      emailError.classList.remove('hidden');
      emailInput.classList.remove('border-green-500', 'border-gray-300');
      emailInput.classList.add('border-red-400');
    } else {
      emailError.classList.add('hidden');
      emailInput.classList.remove('border-red-400', 'border-green-500');
      emailInput.classList.add('border-gray-300');
    }
    return valid;
  }

  emailInput?.addEventListener('input', () => validateEmail(false));
  emailInput?.addEventListener('blur',  () => validateEmail(true));

  document.getElementById('register-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearFormError();

    const password = passwordInput.value;
    const confirm = confirmInput.value;
    const reqs = checkPasswordRequirements(password);

    if (password !== confirm) {
      showFormError('Passwords do not match. Please make sure both fields are identical.');
      return;
    }

    const metCount = Object.values(reqs).filter(Boolean).length;
    if (metCount < 3) {
      showFormError('Your password is too weak. Please meet at least 3 of the requirements listed above.');
      return;
    }

    const phoneResult = parsePHPhone(phoneInput.value.trim());
    if (!phoneResult.valid) {
      validatePhone(true);
      showFormError(phoneResult.error);
      return;
    }

    if (!validateEmail(true)) {
      showFormError('Enter a valid email address (e.g. juan@example.com).');
      return;
    }

    const form = e.target as HTMLFormElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating account...';

    try {
      const { actions } = await import('astro:actions');
      const { error } = await actions.auth.register({
        first_name: (document.getElementById('first_name') as HTMLInputElement).value.trim(),
        last_name: (document.getElementById('last_name') as HTMLInputElement).value.trim(),
        phone: phoneResult.e164,
        email: (document.getElementById('email') as HTMLInputElement).value.trim(),
        password,
        turnstileToken,
      });

      if (error) {
        showFormError(error.message || 'Registration failed. Please try again.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
        window.turnstile?.reset('#register-turnstile');
        turnstileToken = '';
        return;
      }

      showToast('Account created successfully! Redirecting to sign in...', 'success');
      setTimeout(() => { window.location.href = '/auth/login'; }, 1500);
    } catch {
      showFormError('Unable to reach the server. Please check your connection and try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create Account';
    }
  });
</script>

<style>
  @keyframes toast-in {
    from { opacity: 0; transform: translateX(100%); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .animate-toast-in {
    animation: toast-in 0.25s ease-out;
  }
</style>
