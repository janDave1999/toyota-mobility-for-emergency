---
import Container from '../components/layout/Container.astro';
import { Button } from '../components';
import Toast from '../components/common/Toast.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased bg-gray-50 min-h-screen">
    <div class="min-h-screen flex">
      <!-- Left Side - Form -->
      <div class="flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8">
          <slot />
        </div>
      </div>

      <!-- Right Side - Image/Branding -->
      <div class="hidden lg:flex lg:flex-1 bg-toyota-red items-center justify-center p-12">
        <div class="max-w-lg text-center">
          <a href="/" class="inline-flex items-center gap-3 mb-8">
            <div class="bg-white w-14 h-14 rounded-xl flex items-center justify-center">
              <svg class="text-toyota-red w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
          </a>
          <h2 class="text-3xl font-bold text-white mb-4">
            Toyota Mobility for Emergency
          </h2>
          <p class="text-white/80 text-lg">
            Unified Emergency Response Platform for the Philippines. Quick response, saving lives.
          </p>
        </div>
      </div>
    </div>
    
    <Toast />
  </body>
</html>

<style is:global>
  * {
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
</style>
