---
import { actions } from 'astro:actions';
import '../../styles/global.css';

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const { data, error: actionError } = await Astro.callAction(actions.auth.login, {
    email: formData.get('email') as string,
    password: formData.get('password') as string,
  });
  if (data?.redirect) {
    return Astro.redirect(data.redirect);
  }
  if (actionError) {
    error = actionError.message;
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Toyota Emergency Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex font-sans antialiased">

    <!-- Left branding panel -->
    <div class="hidden lg:flex lg:w-1/2 bg-black flex-col justify-between p-12 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-[#EB0A1E]"></div>

      <div>
        <div class="flex items-center gap-3 mb-16">
          <div class="w-10 h-10 bg-[#EB0A1E] rounded-lg flex items-center justify-center shrink-0">
            <span class="text-white font-bold text-lg leading-none">T</span>
          </div>
          <span class="text-white font-semibold text-lg tracking-wide">Toyota Emergency</span>
        </div>

        <h1 class="text-white text-4xl font-bold leading-tight mb-4">
          Emergency<br />Response<br />Admin Portal
        </h1>
        <p class="text-[#58595B] text-base leading-relaxed max-w-xs">
          Manage dispatchers, responders, and emergency operations across the Philippines.
        </p>
      </div>

      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-[#10B981]"></div>
        <span class="text-[#58595B] text-sm">System operational</span>
      </div>
    </div>

    <!-- Right form panel -->
    <div class="flex-1 flex items-center justify-center bg-white px-8 py-12">
      <div class="w-full max-w-sm">

        <!-- Mobile logo -->
        <div class="flex items-center gap-3 mb-10 lg:hidden">
          <div class="w-8 h-8 bg-[#EB0A1E] rounded-lg flex items-center justify-center shrink-0">
            <span class="text-white font-bold leading-none">T</span>
          </div>
          <span class="font-semibold text-gray-900">Toyota Emergency</span>
        </div>

        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">Sign in</h2>
          <p class="text-[#58595B] text-sm">Admin and Dispatcher access only</p>
        </div>

        {error && (
          <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            {error}
          </div>
        )}

        <form method="POST" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
              Email address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full h-12 px-4 border border-[#D1D5DB] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#EB0A1E] focus:border-transparent transition"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full h-12 px-4 border border-[#D1D5DB] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#EB0A1E] focus:border-transparent transition"
              placeholder="••••••••"
            />
          </div>

          <button
            type="submit"
            class="w-full h-14 bg-[#EB0A1E] text-white rounded-lg font-semibold text-sm uppercase tracking-wide hover:bg-[#C40819] transition-colors duration-150"
          >
            Sign In
          </button>
        </form>

        <p class="mt-8 text-center text-xs text-[#58595B]">
          <a href="/" class="hover:text-[#EB0A1E] transition-colors">← Back to Public App</a>
        </p>

      </div>
    </div>

  </body>
</html>
