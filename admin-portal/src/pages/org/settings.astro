---
import AdminLayout from '../../layouts/AdminLayout.astro';
const user = Astro.locals.user;
---

<AdminLayout title="Settings" role="DISPATCHER">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Settings</h1>
    <p class="text-gray-500 mt-1">Manage organization settings</p>
  </div>
  
  <div class="max-w-2xl space-y-6">
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Organization Info</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
          <p class="text-gray-900">{user?.first_name} {user?.last_name}</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <p class="text-gray-900">{user?.email}</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Your Role</label>
          <p class="text-gray-900">{user?.roles?.[0]?.name || 'N/A'}</p>
        </div>
      </div>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Notification Settings</h2>
      <div class="space-y-4">
        <label class="flex items-center gap-3">
          <input type="checkbox" class="w-5 h-5 text-red-600 rounded" checked />
          <span class="text-gray-700">Email notifications for new incidents</span>
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" class="w-5 h-5 text-red-600 rounded" checked />
          <span class="text-gray-700">Push notifications for dispatch requests</span>
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" class="w-5 h-5 text-red-600 rounded" />
          <span class="text-gray-700">Daily summary reports</span>
        </label>
      </div>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Response Settings</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Auto-assign nearby responders</label>
          <select class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500">
            <option>Disabled</option>
            <option>Enabled - Within 1km</option>
            <option>Enabled - Within 5km</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Backup request threshold (minutes)</label>
          <input type="number" value="10" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500" />
        </div>
      </div>
    </div>
    
    <button class="bg-red-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-red-700 transition">
      Save Changes
    </button>
  </div>
</AdminLayout>
