---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { actions } from 'astro:actions';
import ConfirmModal from '../../../components/common/ConfirmModal.astro';
import Toast from '../../../components/common/Toast.astro';

const { id } = Astro.params;
const memberId     = Astro.url.searchParams.get('mid') ?? '';
const memberStatus = Astro.url.searchParams.get('status') ?? '';
const memberRole   = Astro.url.searchParams.get('role') ?? '';
const orgId        = Astro.url.searchParams.get('org_id') ?? Astro.cookies.get('active_org_id')?.value ?? '';

let actionError = '';
let actionSuccess = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent   = formData.get('intent') as string;

  if (intent === 'revoke' && memberId && orgId) {
    const { error } = await Astro.callAction(actions.org.revokeMember, {
      org_id: orgId, member_id: memberId,
    });
    if (!error) actionSuccess = 'Member access revoked.';
    else actionError = error.message;
  }

  if (intent === 'kick' && memberId && orgId) {
    const { error } = await Astro.callAction(actions.org.kickMember, {
      org_id: orgId, member_id: memberId,
    });
    if (!error) return Astro.redirect('/org/members');
    else actionError = error.message;
  }

  if (intent === 'cancel_invite' && memberId && orgId) {
    const { error } = await Astro.callAction(actions.org.cancelInvite, {
      org_id: orgId, member_id: memberId,
    });
    if (!error) return Astro.redirect('/org/members');
    else actionError = error.message;
  }
}
console.log('[member detail] URL id param:', id, '| mid query param:', memberId, '| org:', orgId);
const { data: user, error: userError } = await Astro.callAction(actions.org.getUser, { id: id! });
console.log('Loaded user:', user, 'Error:', userError);
---

<AdminLayout title="Member Details" activeNav="members">

  {userError ? (
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <p class="text-red-600 font-medium mb-2">Failed to load member details</p>
      <p class="text-sm text-gray-400 mb-6">{userError.message}</p>
      <a href="/org/members" class="text-sm text-[#EB0A1E] hover:underline">← Back to Members</a>
    </div>
  ) : (
    <Fragment>
      <!-- Header -->
      <div class="mb-6">
        <a href="/org/members" class="text-gray-500 hover:text-gray-700 flex items-center gap-2 text-sm mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Members
        </a>
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 bg-gray-200 rounded-full flex items-center justify-center shrink-0 overflow-hidden">
            {user.profile_image_url
              ? <img src={user.profile_image_url} alt={user.first_name} class="w-full h-full object-cover" />
              : <span class="text-2xl font-semibold text-gray-600">{user.first_name?.charAt(0) ?? '?'}</span>
            }
          </div>
          <div>
            <h1 class="text-3xl font-bold text-gray-900">{user.first_name} {user.last_name}</h1>
            <p class="text-gray-500 text-sm mt-0.5">{user.email}</p>
          </div>
        </div>
      </div>

      <!-- Alerts -->
      {actionError && (
        <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          {actionError}
        </div>
      )}
      {actionSuccess && (
        <div class="flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          {actionSuccess}
        </div>
      )}

      <!-- Content -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Profile info -->
        <div class="lg:col-span-2 space-y-6">

          <div class="bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Personal Information</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 text-sm">
              <div>
                <dt class="text-gray-500 mb-1">First Name</dt>
                <dd class="font-medium text-gray-900">{user.first_name || '—'}</dd>
              </div>
              <div>
                <dt class="text-gray-500 mb-1">Last Name</dt>
                <dd class="font-medium text-gray-900">{user.last_name || '—'}</dd>
              </div>
              <div>
                <dt class="text-gray-500 mb-1">Email</dt>
                <dd class="font-medium text-gray-900 break-all">{user.email || '—'}</dd>
              </div>
              <div>
                <dt class="text-gray-500 mb-1">Phone</dt>
                <dd class="font-medium text-gray-900">{user.phone || '—'}</dd>
              </div>
            </dl>
          </div>

          <div class="bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Roles</h2>
            {user.roles?.length
              ? (
                <div class="flex flex-wrap gap-2">
                  {user.roles.map((r: any) => (
                    <span class="px-3 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-700">
                      {r.name ?? r}
                    </span>
                  ))}
                </div>
              )
              : <p class="text-sm text-gray-400">No roles assigned.</p>
            }
          </div>

        </div>

        <!-- Sidebar -->
        <div class="space-y-6">

          <div class="bg-white rounded-xl shadow-sm p-6">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Account</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-gray-500">User ID</dt>
                <dd class="font-mono text-xs text-gray-900 truncate max-w-[140px]" title={user.id}>{user.id}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Status</dt>
                <dd>
                  <span class={`px-2 py-1 text-xs font-medium rounded-full ${user.is_active !== false ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                    {user.is_active !== false ? 'Active' : 'Inactive'}
                  </span>
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Joined</dt>
                <dd class="text-gray-900">{user.created_at ? new Date(user.created_at).toLocaleDateString() : '—'}</dd>
              </div>
            </dl>
          </div>

          {memberId && memberRole !== 'ORG_ADMIN' && (
            <div class="bg-white rounded-xl shadow-sm p-6">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Membership Actions</h3>
              <div class="space-y-2">
                {memberStatus === 'INVITED' && (
                  <form method="POST"
                    data-confirm-title="Cancel Invitation"
                    data-confirm-message="Cancel this invitation? The user will need to be re-invited."
                    data-confirm-label="Cancel Invitation">
                    <input type="hidden" name="intent" value="cancel_invite" />
                    <button type="submit"
                      class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm hover:bg-gray-50 transition">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                      Cancel Invitation
                    </button>
                  </form>
                )}
                {memberStatus === 'ACTIVE' && (
                  <Fragment>
                    <form method="POST"
                      data-confirm-title="Revoke Access"
                      data-confirm-message="Revoke this member's access? They will remain in the organization but lose active status."
                      data-confirm-label="Revoke">
                      <input type="hidden" name="intent" value="revoke" />
                      <button type="submit"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-yellow-300 text-yellow-700 rounded-lg text-sm hover:bg-yellow-50 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                        </svg>
                        Revoke Access
                      </button>
                    </form>
                    <form method="POST"
                      data-confirm-title="Kick Member"
                      data-confirm-message="Kick this member? They will be permanently removed from the organization."
                      data-confirm-label="Kick">
                      <input type="hidden" name="intent" value="kick" />
                      <button type="submit"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-red-200 text-red-600 rounded-lg text-sm hover:bg-red-50 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"/>
                        </svg>
                        Kick Member
                      </button>
                    </form>
                  </Fragment>
                )}
                {memberStatus === 'REVOKED' && (
                  <form method="POST"
                    data-confirm-title="Remove Member"
                    data-confirm-message="Permanently remove this member from the organization? This cannot be undone."
                    data-confirm-label="Remove">
                    <input type="hidden" name="intent" value="kick" />
                    <button type="submit"
                      class="w-full flex items-center justify-center gap-2 px-4 py-2 border border-red-200 text-red-600 rounded-lg text-sm hover:bg-red-50 transition">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"/>
                      </svg>
                      Remove Member
                    </button>
                  </form>
                )}
              </div>
            </div>
          )}

        </div>
      </div>
    </Fragment>
  )}

  <ConfirmModal />
  <Toast />

</AdminLayout>

<script>
  import { openModal } from '../../../lib/modal';

  document.querySelectorAll<HTMLFormElement>('form[data-confirm-title]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      openModal(
        form.dataset.confirmTitle!,
        form.dataset.confirmMessage!,
        form.dataset.confirmLabel!,
        async () => { form.submit(); },
      );
    });
  });
</script>
