---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { actions } from 'astro:actions';

let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const org_id   = formData.get('org_id') as string;
  const user_id  = formData.get('user_id') as string;
  const org_role = formData.get('org_role') as 'RESPONDER' | 'DISPATCHER';
  const responder_type = formData.get('responder_type') as string || undefined;

  const { error: actionError } = await Astro.callAction(actions.org.inviteMember, {
    org_id,
    user_id,
    org_role,
    responder_type: responder_type ?? null,
  });

  if (!actionError) {
    success = true;
  } else {
    error = actionError.message;
  }
}

const orgId = Astro.cookies.get('active_org_id')?.value ?? '';

const { data: org } = await Astro.callAction(actions.admin.getOrganization, { id: orgId });
const responderTypes: string[] = org?.allowed_responder_types ?? [];
---

<AdminLayout title="Add Member" role="DISPATCHER">
  <div class="mb-8">
    <a href="/org/members" class="text-gray-500 hover:text-gray-700 flex items-center gap-2 mb-4 text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Members
    </a>
    <h1 class="text-3xl font-bold text-gray-900">Add Team Member</h1>
    <p class="text-gray-500 mt-1">Search for a registered user and invite them to your organization</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm p-8 max-w-2xl">

    {success && (
      <div class="flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        Member invited successfully.
        <a href="/org/members" class="ml-auto font-medium underline">View Members</a>
      </div>
    )}

    {error && (
      <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
        <svg class="w-4 h-4 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        {error}
      </div>
    )}

    <!-- Step 1: Search -->
    <div class="mb-6">
      <label for="user-search" class="block text-sm font-medium text-gray-700 mb-1.5">
        Search User <span class="text-red-500">*</span>
      </label>
      <div class="relative">
        <input
          type="text"
          id="user-search"
          data-org-id={orgId}
          autocomplete="off"
          placeholder="Search by name, email, or phone…"
          class="w-full h-11 pl-10 pr-4 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#EB0A1E] focus:border-transparent"
        />
        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <div id="search-spinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
          <svg class="w-4 h-4 animate-spin text-gray-400" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
        </div>
      </div>
      <!-- Dropdown results -->
      <div id="search-results" class="hidden mt-1 border border-gray-200 rounded-lg shadow-md bg-white max-h-60 overflow-y-auto divide-y divide-gray-100 z-10 relative"></div>
    </div>

    <!-- Step 2: Selected user card -->
    <div id="selected-user" class="hidden mb-6 flex items-center gap-3 p-4 bg-gray-50 border border-gray-200 rounded-lg">
      <div id="selected-avatar" class="w-10 h-10 bg-[#EB0A1E] rounded-full flex items-center justify-center shrink-0">
        <span id="selected-initial" class="text-white text-sm font-semibold"></span>
      </div>
      <div class="flex-1 min-w-0">
        <div id="selected-name" class="font-medium text-gray-900 text-sm"></div>
        <div id="selected-email" class="text-xs text-gray-500 truncate"></div>
      </div>
      <button type="button" id="clear-user" class="text-gray-400 hover:text-gray-600 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Step 3: Role form (only shown after user selected) -->
    <form method="POST" id="invite-form" class="hidden space-y-5">
      <input type="hidden" name="org_id" value={orgId} />
      <input type="hidden" id="user_id" name="user_id" />

      <div>
        <label for="org_role" class="block text-sm font-medium text-gray-700 mb-1.5">
          Role <span class="text-red-500">*</span>
        </label>
        <select id="org_role" name="org_role" required
          class="w-full h-11 px-4 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#EB0A1E] focus:border-transparent">
          <option value="RESPONDER">Responder</option>
          <option value="DISPATCHER">Dispatcher</option>
        </select>
      </div>

      <div id="responder-type-field">
        <label for="responder_type" class="block text-sm font-medium text-gray-700 mb-1.5">
          Responder Type
          {org?.type === 'PRIVATE' && <span class="text-red-500">*</span>}
        </label>

        <select id="responder_type" name="responder_type"
          required={org?.type === 'PRIVATE'}
          class="w-full h-11 px-4 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#EB0A1E] focus:border-transparent">
          <option value="">— Select type —</option>
          {responderTypes.map((t) => <option value={t}>{t.replace(/_/g, ' ')}</option>)}
        </select>

        <p class="text-xs text-gray-400 mt-1">
          {org?.type === 'PRIVATE' ? 'Required for private organizations.' : 'Optional.'}
        </p>
      </div>

      <div class="flex items-center gap-4 pt-2">
        <button type="submit"
          class="bg-[#EB0A1E] text-white px-6 py-3 rounded-lg font-semibold text-sm uppercase tracking-wide hover:bg-[#C40819] transition-colors">
          Send Invitation
        </button>
        <a href="/org/members"
          class="px-6 py-3 border border-gray-300 rounded-lg text-sm font-medium hover:bg-gray-50 transition">
          Cancel
        </a>
      </div>
    </form>

  </div>
</AdminLayout>

<script>
  import { actions } from 'astro:actions';

  const searchInput  = document.getElementById('user-search') as HTMLInputElement;
  const resultsBox   = document.getElementById('search-results')!;
  const spinner      = document.getElementById('search-spinner')!;
  const selectedCard = document.getElementById('selected-user')!;
  const selectedName  = document.getElementById('selected-name')!;
  const selectedEmail = document.getElementById('selected-email')!;
  const clearBtn     = document.getElementById('clear-user')!;
  const inviteForm   = document.getElementById('invite-form')!;
  const userIdInput  = document.getElementById('user_id') as HTMLInputElement;
  const roleSelect   = document.getElementById('org_role') as HTMLSelectElement;
  const responderField = document.getElementById('responder-type-field')!;

  let debounceTimer: ReturnType<typeof setTimeout>;

  function showResults(users: any[]) {
    if (!users.length) {
      resultsBox.innerHTML = `<p class="px-4 py-3 text-sm text-gray-500">No users found.</p>`;
      resultsBox.classList.remove('hidden');
      return;
    }
    resultsBox.innerHTML = users.map((u) => {
      const avatar = u.profile_image_url
        ? `<img src="${u.profile_image_url}" alt="" class="w-8 h-8 rounded-full object-cover shrink-0" />`
        : `<div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center shrink-0 text-xs font-semibold text-gray-600">${u.first_name?.charAt(0) ?? '?'}</div>`;

      if (u.is_member) {
        return `
          <div class="w-full flex items-center gap-3 px-4 py-3 opacity-50 cursor-not-allowed">
            ${avatar}
            <div class="min-w-0 flex-1">
              <div class="text-sm font-medium text-gray-900">${u.first_name} ${u.last_name}</div>
              <div class="text-xs text-gray-400 truncate">${u.email}${u.phone ? ' · ' + u.phone : ''}</div>
            </div>
            <span class="text-xs text-gray-400 shrink-0">Already a member</span>
          </div>
        `;
      }

      return `
        <button type="button" data-id="${u.id}" data-name="${u.first_name} ${u.last_name}" data-email="${u.email}" data-img="${u.profile_image_url ?? ''}"
          class="w-full flex items-center gap-3 px-4 py-3 hover:bg-gray-50 text-left transition">
          ${avatar}
          <div class="min-w-0">
            <div class="text-sm font-medium text-gray-900">${u.first_name} ${u.last_name}</div>
            <div class="text-xs text-gray-400 truncate">${u.email}${u.phone ? ' · ' + u.phone : ''}</div>
          </div>
        </button>
      `;
    }).join('');
    resultsBox.classList.remove('hidden');

    resultsBox.querySelectorAll('[data-id]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        selectUser(el.dataset.id!, el.dataset.name!, el.dataset.email!, el.dataset.img!);
      });
    });
  }

  function selectUser(id: string, name: string, email: string, imgUrl: string) {
    userIdInput.value = id;
    selectedName.textContent  = name;
    selectedEmail.textContent = email;

    const avatarEl = document.getElementById('selected-avatar')!;
    if (imgUrl) {
      avatarEl.innerHTML = `<img src="${imgUrl}" alt="" class="w-10 h-10 rounded-full object-cover" />`;
    } else {
      avatarEl.innerHTML = `<span id="selected-initial" class="text-white text-sm font-semibold">${name.charAt(0).toUpperCase()}</span>`;
    }

    selectedCard.classList.remove('hidden');
    inviteForm.classList.remove('hidden');
    searchInput.classList.add('hidden');
    resultsBox.classList.add('hidden');
  }

  function clearUser() {
    userIdInput.value = '';
    selectedCard.classList.add('hidden');
    inviteForm.classList.add('hidden');
    searchInput.classList.remove('hidden');
    searchInput.value = '';
    searchInput.focus();
  }

  clearBtn.addEventListener('click', clearUser);

  roleSelect.addEventListener('change', () => {
    responderField.classList.toggle('hidden', roleSelect.value !== 'RESPONDER');
  });

  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const q = searchInput.value.trim();

    if (!q) {
      resultsBox.classList.add('hidden');
      return;
    }

    debounceTimer = setTimeout(async () => {
      spinner.classList.remove('hidden');
      const orgId = searchInput.dataset.orgId;
      const { data, error } = await actions.admin.searchUsers({ q, ...(orgId ? { org_id: orgId } : {}) });
      spinner.classList.add('hidden');

      if (error) {
        resultsBox.innerHTML = `<p class="px-4 py-3 text-sm text-red-500">${error.message}</p>`;
        resultsBox.classList.remove('hidden');
        return;
      }

      showResults(Array.isArray(data) ? data : []);
    }, 300);
  });

  // Hide dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target as Node) && !resultsBox.contains(e.target as Node)) {
      resultsBox.classList.add('hidden');
    }
  });
</script>
