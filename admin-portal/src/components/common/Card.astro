---
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { 
  class: className = '',
  padding = 'md'
} = Astro.props;

const paddingClasses = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const classes = [
  'bg-white rounded-xl shadow-sm border border-gray-100',
  paddingClasses[padding],
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
