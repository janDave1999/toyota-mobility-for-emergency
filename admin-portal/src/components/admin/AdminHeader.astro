---
interface Props {
  title: string;
}

const { title } = Astro.props;

const user = Astro.locals.user;
const activeRole = Astro.locals.activeRole;

const isAdmin = activeRole === 'ADMIN';

const ROLE_META: Record<string, { label: string; pill: string }> = {
  ADMIN:      { label: 'Admin',      pill: 'bg-purple-100 text-purple-700' },
  DISPATCHER: { label: 'Dispatcher', pill: 'bg-blue-100 text-blue-700' },
};
---

<header class="h-16 bg-white border-b border-gray-200 px-6 flex items-center justify-between sticky top-0 z-20">
  <!-- Page Title -->
  <div>
    <h1 class="text-lg font-semibold text-gray-900">{title}</h1>
  </div>
  
  <!-- Right Side -->
  <div class="flex items-center gap-4">
    <!-- Role Badge -->
    {activeRole && ROLE_META[activeRole] && (
      <span class={`px-3 py-1 rounded-full text-xs font-semibold ${ROLE_META[activeRole].pill}`}>
        {ROLE_META[activeRole].label}
      </span>
    )}
    
    <!-- Notifications -->
    <button 
      class="relative p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
      aria-label="Notifications"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
      </svg>
      <span class="absolute top-1 right-1 w-2 h-2 bg-toyota-red rounded-full"></span>
    </button>
    
    <!-- User Menu -->
    <div class="flex items-center gap-3 pl-4 border-l border-gray-200">
      <div class="text-right hidden sm:block">
        <p class="text-sm font-medium text-gray-900">
          {user?.first_name} {user?.last_name}
        </p>
        <p class="text-xs text-gray-500">{user?.email}</p>
      </div>
      <div class="w-9 h-9 bg-gray-200 rounded-full flex items-center justify-center">
        <span class="text-sm font-medium text-gray-600">
          {user?.first_name?.charAt(0) || user?.email?.charAt(0) || '?'}
        </span>
      </div>
    </div>
  </div>
</header>
